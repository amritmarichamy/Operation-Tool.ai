# ============================================================
# Terra Tern CRM — Environment Configuration
# Copy this file to .env and fill in real values.
# ============================================================

# ---- Server ----
CRM_PORT=8080
CRM_DEBUG=false
CRM_SECRET_KEY=change-me-to-a-random-string

# ---- Database ----
# Path is relative to the project root (default: data/crm.sqlite3)
CRM_SQLITE_PATH=data/crm.sqlite3

# ---- SMTP (Gmail) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com

# ---- OTP Email Sender ----
# Use a Gmail App Password, NOT your real Gmail password.
OTP_EMAIL=your-email@example.com
OTP_PASS=xxxx-xxxx-xxxx-xxxx

# ---- Email Validation ----
ENABLE_MX_CHECK=false
STRICT_BLOCK_INVALID_TARGETS=true
ENABLE_BOUNCE_CHECK_DEFAULT=true

# ---- Automation ----
SMART_AUTOMATION_BACKLOG_SAFE_CAP=100
AUTOMATION_DAILY_CAP_WHEN_NO_BACKLOG=500
AUTOMATION_DEFAULT_DELAY_SECONDS=10

# ---- External Services ----
CRM_JSA_ENROLLMENT_UPDATE_PREFIX=https://backend.terratern.com/jsa-enrollment/update?id=

# ---- Retry ----
MAX_RETRIES=5
RETRY_BASE_SECONDS=3
NETWORK_WAIT_SECONDS=8
